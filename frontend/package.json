{
  "name": "gym-nexus-frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:admin": "pnpm --filter admin-web run dev",
    "dev:member": "pnpm --filter member-app run dev",
    "build": "pnpm -r run build",
    "build:admin": "pnpm --filter admin-web run build",
    "build:member": "pnpm --filter member-app run build",
    "generate:icons": "pnpm -r run generate:icons",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "cd .. && husky || true"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.21.0",
    "@playwright/test": "^1.57.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "3.2.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "sharp": "^0.34.5",
    "vitest": "^3.2.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,vue}": [
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@directus/sdk": "^20.3.0"
  }
}
