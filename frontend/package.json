{
  "name": "gym-nexus-frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "dev:admin": "pnpm --filter admin-web run dev",
    "dev:member": "pnpm --filter member-app run dev",
    "build": "pnpm -r run build",
    "build:admin": "pnpm --filter admin-web run build",
    "build:member": "pnpm --filter member-app run build",
    "generate:icons": "pnpm -r run generate:icons",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxi typecheck",
    "typecheck:admin": "pnpm --filter admin-web exec nuxi typecheck",
    "typecheck:member": "pnpm --filter member-app exec nuxi typecheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect --config=lighthouserc.cjs",
    "lighthouse:assert": "lhci assert --config=lighthouserc.cjs",
    "lighthouse:upload": "lhci upload --config=lighthouserc.cjs",
    "lighthouse:admin": "lhci autorun --config=lighthouserc.cjs --collect.url=http://localhost:3000/ --collect.url=http://localhost:3000/login --collect.url=http://localhost:3000/members",
    "lighthouse:member": "lhci autorun --config=lighthouserc.cjs --collect.url=http://localhost:3001/ --collect.url=http://localhost:3001/login --collect.url=http://localhost:3001/bookings",
    "prepare": "cd .. && husky || true",
    "lint-staged": "pnpm exec lint-staged"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@eslint/js": "^9.39.2",
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/test-utils": "^3.21.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vite-pwa/nuxt": "^1.1.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/compiler-dom": "^3.5.26",
    "@vue/server-renderer": "^3.5.26",
    "@vue/test-utils": "^2.4.6",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nuxt": "^4.2.2",
    "playwright": "^1.57.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.2.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "vue": "^3.5.13",
    "zod": "^4.3.4"
  }
}
