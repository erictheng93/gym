# Member App - Environment Configuration
# =======================================
# Copy this file to .env.local for local development

# Backend API URL
# Local development: http://localhost:8055
# Staging: https://staging-api.gym-nexus.com
# Production: https://api.gym-nexus.com
DIRECTUS_URL=http://localhost:8055

# Development Port (member-app uses 3002)
PORT=3002

# ==============================================
# Sentry Error Tracking (Optional)
# ==============================================
#
# Setup Instructions:
# 1. Create a project at https://sentry.io/
# 2. Get your DSN from Project Settings > Client Keys
# 3. Set the DSN below to enable error tracking
#
# Note: If not set, Sentry will be disabled

# Sentry DSN (Data Source Name)
# Example: https://abc123@o123456.ingest.sentry.io/1234567
NUXT_PUBLIC_SENTRY_DSN=

# Enable Sentry debug mode (development only)
NUXT_PUBLIC_SENTRY_DEBUG=false

# ==============================================
# App Version (Optional)
# ==============================================
# Used for Sentry release tracking and cache busting
# Automatically set by CI/CD pipeline
APP_VERSION=1.0.0
