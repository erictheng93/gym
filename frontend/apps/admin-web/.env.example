# Backend API
API_BASE_URL=http://localhost:8056

# Development Port (admin-web uses 3001)
PORT=3001

# ============================================
# Sentry Error Tracking (Optional)
# ============================================
#
# Setup Instructions:
# 1. Create a project at https://sentry.io/
# 2. Get your DSN from Project Settings > Client Keys
# 3. Set the DSN below to enable error tracking
#
# Note: If not set, Sentry will be disabled

# Sentry DSN (Data Source Name)
# Example: https://abc123@o123456.ingest.sentry.io/1234567
NUXT_PUBLIC_SENTRY_DSN=

# ============================================
# Google Workspace Integration
# ============================================
#
# Setup Instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google Sheets API and Google Drive API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add authorized redirect URIs (e.g., http://localhost:3001/settings/google-integration/callback)
# 6. Copy the credentials below
#

# Google Cloud Project ID
# Example: my-gym-project-123456
NUXT_PUBLIC_GOOGLE_PROJECT_ID=your_project_id_here

# Google OAuth 2.0 Client ID
# Example: 123456789012-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Google OAuth 2.0 Client Secret (Keep this secure!)
# Example: GOCSPX-abcd1234efgh5678ijkl
GOOGLE_CLIENT_SECRET=your_client_secret_here

# OAuth 2.0 Redirect URI
# Must match the authorized redirect URI in Google Cloud Console
# For local development: http://localhost:3001/settings/google-integration/callback
# For production: https://your-domain.com/settings/google-integration/callback
NUXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3001/settings/google-integration/callback

# Google API Scopes (comma-separated, no spaces)
# Default scopes for Sheets and Drive access
NUXT_PUBLIC_GOOGLE_SCOPES=https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/drive.file

# ============================================
# Looker Studio Integration (Optional)
# ============================================
#
# For Looker Studio integration, you need:
# 1. BigQuery dataset for data export
# 2. Service account with BigQuery access
# 3. Looker Studio connected to BigQuery
#
# See docs/LOOKER_STUDIO_SETUP.md for detailed instructions

# BigQuery Project ID (can be same as Google Project ID)
NUXT_PUBLIC_BIGQUERY_PROJECT_ID=your_project_id_here

# BigQuery Dataset ID
# Example: gym_nexus_reports
NUXT_PUBLIC_BIGQUERY_DATASET_ID=gym_nexus_reports

# Service Account Email (for server-side BigQuery operations)
# Example: gym-nexus-sa@my-gym-project-123456.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com

# Path to Service Account Key JSON file
# Store this file securely and never commit to git!
# Example: ./config/google-service-account-key.json
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account-key.json
