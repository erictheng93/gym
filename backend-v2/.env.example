# =============================================================================
# GYM NEXUS API v2 - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://gym_nexus:gym_nexus_dev@localhost:15432/gym_nexus

# =============================================================================
# SERVER
# =============================================================================
PORT=8056
NODE_ENV=development

# Cron Jobs (set to 'false' to disable)
ENABLE_CRON=true

# =============================================================================
# AUTH
# =============================================================================
# Admin/Staff Auth (Lucia.js session)
SESSION_SECRET=your-session-secret-here-min-32-chars

# Member App JWT Secret
MEMBER_JWT_SECRET=your-member-jwt-secret-here-min-32-chars

# Coach App JWT Secret
COACH_JWT_SECRET=your-coach-jwt-secret-here-min-32-chars

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
EMAIL_TRANSPORT=smtp
EMAIL_FROM=Gym Nexus <noreply@gym-nexus.com>
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false

# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gym-nexus.com

# =============================================================================
# LINE MESSAGING API
# =============================================================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=

# =============================================================================
# SMS (Mitake - Taiwan)
# =============================================================================
MITAKE_USERNAME=
MITAKE_PASSWORD=
MITAKE_API_URL=https://smsapi.mitake.com.tw/api/mtk/SmSend

# =============================================================================
# PAYMENT GATEWAYS
# =============================================================================
# Stripe (International)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ECPay (Taiwan - 綠界)
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

# LINE Pay
LINEPAY_CHANNEL_ID=
LINEPAY_CHANNEL_SECRET=

# =============================================================================
# FILE STORAGE (S3/Cloudflare R2)
# =============================================================================
S3_BUCKET=gym-nexus-files
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Cloudflare R2 specific
R2_ACCOUNT_ID=
R2_PUBLIC_URL=

# =============================================================================
# OAUTH PROVIDERS (Social Login)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LINE Login
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# =============================================================================
# FRONTEND URLs (for OAuth callbacks and email links)
# =============================================================================
MEMBER_APP_URL=http://localhost:3001
ADMIN_APP_URL=http://localhost:3000
COACH_APP_URL=http://localhost:3002

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# =============================================================================
# DOCKER (only used in docker-compose)
# =============================================================================
DB_PORT=15432
DB_USER=gym_nexus
DB_PASSWORD=gym_nexus_dev
DB_DATABASE=gym_nexus
API_PORT=8056
TUNNEL_TOKEN=
