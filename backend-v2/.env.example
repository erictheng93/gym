# Database
DATABASE_URL=postgresql://gym_dev:gym_dev_password@localhost:15432/gym_dev

# Server
PORT=8056
NODE_ENV=development

# Cron Jobs (set to 'false' to disable)
ENABLE_CRON=true

# Auth (Lucia)
SESSION_SECRET=your-session-secret-here

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gym-nexus.com

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gym-nexus.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# SMS (Mitake)
SMS_USERNAME=
SMS_PASSWORD=

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gym-nexus-files
R2_PUBLIC_URL=

# Redis (optional, for production caching)
REDIS_URL=redis://localhost:6379

# =============================================================================
# MEMBER-APP AUTH (Phase 8)
# =============================================================================

# Member JWT Secret (separate from admin auth)
MEMBER_JWT_SECRET=your-member-jwt-secret-here

# Member App URL (for OAuth callbacks and email links)
MEMBER_APP_URL=http://localhost:3001

# Google OAuth (for member social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LINE Login (for member social login)
LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET is already defined above for Messaging API

# Apple Sign In (for member social login)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
