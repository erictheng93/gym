# Database
DATABASE_URL=postgresql://directus:directus@localhost:15432/directus

# Server
PORT=8056
NODE_ENV=development

# Auth (Lucia)
SESSION_SECRET=your-session-secret-here

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gym-nexus.com

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gym-nexus.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# SMS (Mitake)
SMS_USERNAME=
SMS_PASSWORD=

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gym-nexus-files
R2_PUBLIC_URL=

# Redis (optional, for production caching)
REDIS_URL=redis://localhost:6379
