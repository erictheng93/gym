# HR Service Environment Configuration

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://hr_user:hr_password@localhost:5432/hr_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h

# Main System Integration
MAIN_SYSTEM_API_URL=http://localhost:8500
MAIN_SYSTEM_API_KEY=your-api-key-here

# Employee Sync
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=15
SYNC_WEBHOOK_SECRET=your-webhook-secret-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
