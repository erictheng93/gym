# =============================================================================
# Gym Nexus API v2 - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Cloudflare Tunnel
# -----------------------------------------------------------------------------
TUNNEL_TOKEN=eyJhIjoixxxxxx...

# -----------------------------------------------------------------------------
# Database (internal, no external access)
# -----------------------------------------------------------------------------
DB_USER=gym_nexus
DB_PASSWORD=<STRONG_PASSWORD_HERE>
DB_DATABASE=gym_nexus

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
API_PORT=8056

# CORS - Cloudflare Pages domains
CORS_ORIGIN=https://admin.imfinethankyouandyou.com,https://app.imfinethankyouandyou.com,https://coach.imfinethankyouandyou.com

# -----------------------------------------------------------------------------
# Authentication Secrets (generate with: openssl rand -base64 32)
# -----------------------------------------------------------------------------
JWT_SECRET=<GENERATE_STRONG_SECRET>
SESSION_SECRET=<GENERATE_STRONG_SECRET>
MEMBER_JWT_SECRET=<GENERATE_STRONG_SECRET>
COACH_JWT_SECRET=<GENERATE_STRONG_SECRET>

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_TRANSPORT=smtp
EMAIL_FROM=Gym Nexus <noreply@imfinethankyouandyou.com>
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Push Notifications (generate at: https://vapidkeys.com/)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@imfinethankyouandyou.com

# -----------------------------------------------------------------------------
# LINE Messaging API
# -----------------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=

# -----------------------------------------------------------------------------
# SMS (Mitake)
# -----------------------------------------------------------------------------
MITAKE_USERNAME=
MITAKE_PASSWORD=
MITAKE_API_URL=https://smsapi.mitake.com.tw/api/mtk/SmSend

# -----------------------------------------------------------------------------
# Payment Gateways
# -----------------------------------------------------------------------------
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ECPay
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

# LINE Pay
LINEPAY_CHANNEL_ID=
LINEPAY_CHANNEL_SECRET=

# -----------------------------------------------------------------------------
# File Storage (Cloudflare R2)
# -----------------------------------------------------------------------------
S3_BUCKET=gym-nexus-files
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# OAuth (Social Login)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
ENABLE_CRON=true
