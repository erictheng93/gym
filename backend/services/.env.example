# BigQuery 資料同步服務設定

# Directus API URL
DIRECTUS_URL=http://localhost:8055

# Google Cloud 專案 ID
GOOGLE_PROJECT_ID=your_project_id_here

# BigQuery 資料集 ID
BIGQUERY_DATASET_ID=gym_nexus_reports

# Google 服務帳號金鑰檔案路徑（相對於 backend 目錄）
# 將服務帳號金鑰 JSON 檔案放在 backend/config/ 目錄下
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account-key.json

# 排程器設定
# 是否在啟動時立即執行一次同步（true/false）
SYNC_ON_STARTUP=false
