# Custom Directus image with extension dependencies
FROM directus/directus:11

USER root

# Install extension dependencies globally so they're available to extensions
RUN npm install -g bcryptjs express-rate-limit ioredis jsonwebtoken rate-limit-redis

# Create symlinks in Directus node_modules for extensions to find
RUN ln -sf /usr/local/lib/node_modules/bcryptjs /directus/node_modules/bcryptjs && \
    ln -sf /usr/local/lib/node_modules/express-rate-limit /directus/node_modules/express-rate-limit && \
    ln -sf /usr/local/lib/node_modules/ioredis /directus/node_modules/ioredis && \
    ln -sf /usr/local/lib/node_modules/jsonwebtoken /directus/node_modules/jsonwebtoken && \
    ln -sf /usr/local/lib/node_modules/rate-limit-redis /directus/node_modules/rate-limit-redis

USER node
