# Gym Nexus Backend Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# OAuth Provider Credentials
# ============================================
# Only configure the providers you want to enable

# Enabled providers (comma-separated)
# Options: google, line, apple, facebook
AUTH_PROVIDERS=google,line

# --- Google OAuth ---
# Create credentials at: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth client ID (Web application)
# 4. Add redirect URI: https://your-domain/auth/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LINE Login ---
# Create channel at: https://developers.line.biz/console/
# 1. Create a Provider
# 2. Create a LINE Login channel
# 3. Set callback URL: https://your-domain/auth/login/line/callback
# Note: Email scope requires OpenID Connect verification
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- Apple Sign In (optional) ---
# Create at: https://developer.apple.com/
# Requires Apple Developer Program ($99/year)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# --- Facebook Login (optional) ---
# Create app at: https://developers.facebook.com/
# Note: Email permission may require App Review
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ============================================
# Directus Configuration
# ============================================

# Member role UUID (created by migration 011)
MEMBER_ROLE_ID=b1000000-0000-0000-0000-000000000001

# Database (if not using docker-compose defaults)
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=gym_nexus
# DB_USER=directus
# DB_PASSWORD=directus

# Security
# SECRET=your-super-secure-random-string-here

# ============================================
# Email Configuration (SMTP)
# ============================================
# Directus uses nodemailer - supports various transports
# Transport: smtp (default), sendmail, mailgun, sendgrid, ses

EMAIL_TRANSPORT=smtp
EMAIL_FROM=Gym Nexus <noreply@gym-nexus.com>

# --- SMTP Settings ---
# Gmail example (requires App Password, not regular password):
#   EMAIL_SMTP_HOST=smtp.gmail.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=your-email@gmail.com
#   EMAIL_SMTP_PASSWORD=your-app-password
#   EMAIL_SMTP_SECURE=false
#
# Outlook/Office365 example:
#   EMAIL_SMTP_HOST=smtp.office365.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=your-email@outlook.com
#   EMAIL_SMTP_PASSWORD=your-password
#
# SendGrid SMTP example:
#   EMAIL_SMTP_HOST=smtp.sendgrid.net
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=apikey
#   EMAIL_SMTP_PASSWORD=your-sendgrid-api-key
#
# Amazon SES example:
#   EMAIL_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=your-ses-access-key
#   EMAIL_SMTP_PASSWORD=your-ses-secret-key

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_IGNORE_TLS=false

# ============================================
# Push Notifications (Web Push / VAPID)
# ============================================
# Generate VAPID keys: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gym-nexus.com
