# Gym Nexus Backend Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# OAuth Provider Credentials
# ============================================
# Only configure the providers you want to enable

# Enabled providers (comma-separated)
# Options: google, line, apple, facebook
AUTH_PROVIDERS=google,line

# --- Google OAuth ---
# Create credentials at: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth client ID (Web application)
# 4. Add redirect URI: https://your-domain/auth/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LINE Login ---
# Create channel at: https://developers.line.biz/console/
# 1. Create a Provider
# 2. Create a LINE Login channel
# 3. Set callback URL: https://your-domain/auth/login/line/callback
# Note: Email scope requires OpenID Connect verification
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- Apple Sign In (optional) ---
# Create at: https://developer.apple.com/
# Requires Apple Developer Program ($99/year)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# --- Facebook Login (optional) ---
# Create app at: https://developers.facebook.com/
# Note: Email permission may require App Review
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ============================================
# CORS Configuration (Production)
# ============================================
# Configure these for production deployment
# Default values are for development (localhost)

# Enable/disable CORS
CORS_ENABLED=true

# Allowed origins (comma-separated)
# Production example: https://member.gym-nexus.com,https://admin.gym-nexus.com
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Allow credentials (cookies, authorization headers)
CORS_CREDENTIALS=true

# Allowed headers (comma-separated)
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Member-Token

# ============================================
# Directus Configuration
# ============================================

# Member role UUID (created by migration 011)
MEMBER_ROLE_ID=b1000000-0000-0000-0000-000000000001

# Database (if not using docker-compose defaults)
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=gym_nexus
# DB_USER=directus
# DB_PASSWORD=directus

# Security
# SECRET=your-super-secure-random-string-here

# ============================================
# Email Configuration (SMTP)
# ============================================
# Directus uses nodemailer - supports various transports
# Transport: smtp (default), sendmail, mailgun, sendgrid, ses

EMAIL_TRANSPORT=smtp
EMAIL_FROM=Gym Nexus <noreply@gym-nexus.com>

# --- SMTP Settings ---
# Gmail example (requires App Password, not regular password):
#   EMAIL_SMTP_HOST=smtp.gmail.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=your-email@gmail.com
#   EMAIL_SMTP_PASSWORD=your-app-password
#   EMAIL_SMTP_SECURE=false
#
# Outlook/Office365 example:
#   EMAIL_SMTP_HOST=smtp.office365.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=your-email@outlook.com
#   EMAIL_SMTP_PASSWORD=your-password
#
# SendGrid SMTP example:
#   EMAIL_SMTP_HOST=smtp.sendgrid.net
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=apikey
#   EMAIL_SMTP_PASSWORD=your-sendgrid-api-key

# ============================================
# Amazon SES Configuration (Recommended)
# ============================================
# SES SMTP Endpoints by Region:
#   ap-northeast-1 (Tokyo):     email-smtp.ap-northeast-1.amazonaws.com
#   ap-southeast-1 (Singapore): email-smtp.ap-southeast-1.amazonaws.com
#   us-east-1 (N. Virginia):    email-smtp.us-east-1.amazonaws.com
#   eu-west-1 (Ireland):        email-smtp.eu-west-1.amazonaws.com
#
# Setup Steps:
# 1. AWS Console > SES > Verified identities > Create identity (domain or email)
# 2. AWS Console > SES > SMTP settings > Create SMTP credentials
# 3. Copy the SMTP username and password below
# 4. Request production access if still in sandbox mode
#
# Cost: $0.10 per 1,000 emails (62,000 free/month if on EC2)

EMAIL_SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_IGNORE_TLS=false

# ============================================
# Push Notifications (Web Push / VAPID)
# ============================================
# Generate VAPID keys: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gym-nexus.com

# ============================================
# LINE Messaging API (Notifications)
# ============================================
# This is separate from LINE Login. You need a Messaging API channel.
# Create at: https://developers.line.biz/console/
# 1. Create a Provider (or use existing)
# 2. Create a "Messaging API" channel (NOT LINE Login)
# 3. Enable "Use webhooks" if needed
# 4. Issue a Channel access token (long-lived)
#
# Note: LINE Messaging API is used for sending notifications to users
# who have linked their LINE account via LINE Login.

LINE_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=

# ============================================
# SMS Gateway (Mitake 三竹簡訊)
# ============================================
# Apply for account at: https://sms.mitake.com.tw/
# API Documentation: https://sms.mitake.com.tw/common/api
#
# SMS is used as a fallback channel when LINE and Push are unavailable.
# Primarily for OTP codes and critical notifications.
#
# Cost: Approximately NT$0.5-1.0 per SMS (varies by contract)

MITAKE_USERNAME=
MITAKE_PASSWORD=
MITAKE_API_URL=https://smsapi.mitake.com.tw/api/mtk/SmSend
MITAKE_COST_PER_SMS=0.5

# SMS sending limits (to prevent abuse)
SMS_DAILY_LIMIT_PER_MEMBER=5
SMS_OTP_ONLY=false
